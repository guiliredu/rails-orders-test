<h2 class="text-xl font-semibold mb-4">Orders</h2>

<%= form_with url: orders_path, method: :get, local: true,
    class: "flex gap-3 mb-6" do %>

  <%= text_field_tag :control_number,
      params[:control_number],
      placeholder: "Control number",
      class: "border px-3 py-2 rounded" %>

  <%= select_tag :state,
      options_for_select(Order.states.keys, params[:state]),
      include_blank: "All states",
      class: "border px-3 py-2 rounded" %>

  <%= submit_tag "Filter",
      class: "bg-gray-800 text-white px-3 py-2 rounded" %>
<% end %>

<div class="bg-white shadow rounded">
  <table class="w-full">
    <thead class="bg-gray-200">
      <tr>
        <th class="p-3 text-left">ID</th>
        <th class="p-3 text-left">Title</th>
        <th class="p-3 text-left">State</th>
        <th class="p-3"></th>
      </tr>
    </thead>

    <tbody>
      <% @orders.each do |order| %>
        <tr class="border-t">
          <td class="p-3"><%= order.control_number %></td>
          <td class="p-3"><%= order.title %></td>
          <td class="p-3 capitalize"><%= order.state %></td>
          <td class="p-3 space-x-3">

            <% if order.pending? %>
              <%= link_to "Start",
                  start_progress_order_path(order),
                  method: :patch,
                  class: "text-blue-600" %>
            <% end %>

            <% if order.in_progress? %>
              <%= link_to "Complete",
                  complete_order_path(order),
                  method: :patch,
                  class: "text-green-600" %>
            <% end %>

          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>